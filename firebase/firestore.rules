rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidPollOption(pollId, optionId) {
      return (pollId == 'autonomy-pattern'
          && optionId in ['search', 'report', 'ai-output', 'soil'])
        || (pollId == 'ai-risk'
          && optionId in ['fast-output', 'dependency', 'surface', 'outsourcing'])
        || (pollId == 'nondelegable-work'
          && optionId in ['question', 'evidence', 'integration', 'revision']);
    }

    function isValidActivePollId(pollId) {
      return pollId == null
        || pollId in ['autonomy-pattern', 'ai-risk', 'nondelegable-work'];
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && sessionId == 'default'
        && request.resource.data.keys().hasOnly(['activePollId', 'updatedAt'])
        && isValidActivePollId(request.resource.data.activePollId);
      allow delete: if false;
    }

    match /sessions/{sessionId}/polls/{pollId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && sessionId == 'default'
        && request.resource.data.keys().hasOnly(['resetTimestamp', 'updatedAt']);
      allow delete: if false;

      match /votes/{userId} {
        allow read: if true;
        allow create, update: if request.auth != null
          && sessionId == 'default'
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['optionId', 'updatedAt'])
          && request.resource.data.optionId is string
          && isValidPollOption(pollId, request.resource.data.optionId);
        allow delete: if false;
      }
    }
  }
}
